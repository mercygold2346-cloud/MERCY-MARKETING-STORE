# Copy to .env.local and restart: npm run dev

# --- Gmail (contact form + order confirmation emails) ---
GMAIL_USER=mercyonic@gmail.com
# Google App Password (16 chars) — NOT your normal Gmail password
# Create at: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=your-app-password-here
CONTACT_TO_EMAIL=mercyonic@gmail.com

# --- WhatsApp ---
NEXT_PUBLIC_WHATSAPP_NUMBER=2349026466738

# --- Paystack (Nigerian payments) ---
# Get keys at: https://dashboard.paystack.com/#/settings/developers
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# USD to NGN rate for Paystack checkout (e.g. 1600 = $1 ≈ ₦1,600)
NGN_EXCHANGE_RATE=1600
